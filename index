<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Movie Finder App</title>

<!-- ONLY allowed libraries -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://unpkg.com/mustache@4.2.0/mustache.min.js"></script>

<style>
body{font-family:Arial;margin:0;background:#f4f6f8}
header{background:#111;color:white;padding:15px;text-align:center}

.tabs{text-align:center;padding:10px;background:#222}
.tabs button{padding:10px;margin:5px}
.activeTab{background:#ff4444;color:white}

.search-section{text-align:center;padding:20px}

.container{display:flex;flex-wrap:wrap;padding:20px}


.movie{background:white;padding:10px;border-radius:8px;cursor:pointer;display:flex;gap:10px}
.movie.grid{flex-direction:column;text-align:center}
.movie img{width:120px;border-radius:6px}

.details-img{width:200px}
.overview{margin-top:10px}


@media(max-width:900px){
.container{flex-direction:column}

}
</style>
</head>

<body>

<header>
<h1>🎬 Movie Finder</h1>
</header>

<!-- TABS -->
<div class="tabs">
    <button id="tabSearch" class="activeTab">Search</button>
    <button id="tabCollection">Collection</button>
</div>

<!-- SEARCH -->
<section id="searchSection" class="search-section">
<input type="text" id="searchBox" placeholder="Search movies...">
<button id="searchBtn">Search</button>
<button id="gridBtn">Grid</button>
<button id="listBtn">List</button>
</section>

<section id="pagination"></section>

<div class="container">
    <div id="results"></div>

    <div id="details">
        <h2>Movie Details</h2>
        <p>Select a movie to see details.</p>
    </div>
</div>

<!-- COLLECTION -->
<section id="collectionSection" style="display:none;">
<h2 style="text-align:center">⭐ Popular Movies</h2>
<div id="collection"></div>
</section>

<!-- MUSTACHE TEMPLATES -->
<script id="movie-card-template" type="x-tmpl-mustache">
<div class="movie {{viewMode}}" data-movie='{{json}}'>
    <img src="{{poster}}">
    <div>
        <h3>{{title}}</h3>
        <p>⭐ {{rating}}</p>
        <p>{{release}}</p>
    </div>
</div>
</script>

<script id="movie-details-template" type="x-tmpl-mustache">
<h2>{{title}}</h2>
<img src="{{poster}}" class="details-img">
<p><b>Release:</b> {{release}}</p>
<p><b>Rating:</b> ⭐ {{rating}}</p>
<p><b>Language:</b> {{language}}</p>
<p class="overview">{{overview}}</p>
</script>

<script>
const API_KEY="73906d492d324e7602c0719c3a8324ac";
const IMG="https://image.tmdb.org/t/p/w500";

let allResults=[];
let currentPage=1;
let resultsPerPage=10;
let viewMode="grid";

////////////////////////////////////////////////
// TAB SWITCHING (SPA)
////////////////////////////////////////////////
$("#tabSearch").click(()=>{
    $("#searchSection,.container,#pagination").show();
    $("#collectionSection").hide();
    $(".tabs button").removeClass("activeTab");
    $("#tabSearch").addClass("activeTab");
});

$("#tabCollection").click(()=>{
    $("#searchSection,.container,#pagination").hide();
    $("#collectionSection").show();
    $(".tabs button").removeClass("activeTab");
    $("#tabCollection").addClass("activeTab");
});

////////////////////////////////////////////////
// GRID / LIST VIEW
////////////////////////////////////////////////
$("#gridBtn").click(()=>{viewMode="grid";displayPage();});
$("#listBtn").click(()=>{viewMode="list";displayPage();});

////////////////////////////////////////////////
// SEARCH MOVIES
////////////////////////////////////////////////
$("#searchBtn").click(()=>{
    let query=$("#searchBox").val();
    $.get(`https://api.themoviedb.org/3/search/movie?api_key=${API_KEY}&query=${query}`,data=>{
        allResults=data.results.slice(0,50);
        currentPage=1;
        createPagination();
        displayPage();
    });
});

////////////////////////////////////////////////
// PAGINATION
////////////////////////////////////////////////
function createPagination(){
    $("#pagination").empty();
    let pages=Math.ceil(allResults.length/resultsPerPage);
    $("#pagination").append(`<h3>Page ${currentPage} of ${pages}</h3>`);
    for(let i=1;i<=pages;i++){
        $("#pagination").append(`<button onclick="goToPage(${i})">${i}</button>`);
    }
}
function goToPage(p){currentPage=p;displayPage();}

////////////////////////////////////////////////
// MUSTACHE RENDER
////////////////////////////////////////////////
function renderMovies(movies,target){
    const template=$("#movie-card-template").html();
    $(target).empty().removeClass("list grid").addClass(viewMode);

    movies.forEach(m=>{
        let html=Mustache.render(template,{
            title:m.title,
            poster:IMG+m.poster_path,
            rating:m.vote_average,
            release:m.release_date,
            json:JSON.stringify(m),
            viewMode:viewMode
        });
        $(target).append(html);
    });
}

////////////////////////////////////////////////
// DISPLAY PAGE
////////////////////////////////////////////////
function displayPage(){
    let start=(currentPage-1)*resultsPerPage;
    let pageItems=allResults.slice(start,start+resultsPerPage);
    renderMovies(pageItems,"#results");
}

////////////////////////////////////////////////
// DETAILS ON DEMAND
////////////////////////////////////////////////
$(document).on("click",".movie",function(){
    let movie=$(this).data("movie");
    const template=$("#movie-details-template").html();

    let html=Mustache.render(template,{
        title:movie.title,
        poster:IMG+movie.poster_path,
        rating:movie.vote_average,
        release:movie.release_date,
        language:movie.original_language.toUpperCase(),
        overview:movie.overview
    });
    $("#details").html(html);
});

////////////////////////////////////////////////
// LOAD POPULAR COLLECTION
////////////////////////////////////////////////
$(document).ready(()=>{
    $.get(`https://api.themoviedb.org/3/movie/popular?api_key=${API_KEY}`,data=>{
        renderMovies(data.results.slice(0,12),"#collection");
    });
});
</script>

</body>
</html>
